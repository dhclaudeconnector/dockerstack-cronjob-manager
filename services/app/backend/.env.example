# ============================================================
# cronjob-manager — Environment Configuration
# Every JSON-shaped ENV is parsed with base64 → raw fallback,
# so you can paste raw JSON in dev or base64 in prod/CI safely.
# ============================================================

# --- Server ---
PORT=8080
LOG_LEVEL=info            # trace | debug | info | warn | error
LOG_FORMAT=json           # json | pretty

# --- Auth between frontend & backend (REQUIRED) ---
API_SECRET=change-me-super-secret        # required for every /api call (header x-api-secret)
TINYAUTH_ENABLED=true
TINYAUTH_USERS={"admin":"admin-pass"}    # JSON (base64-able)

# --- Firebase RTDB (choose ONE auth mode) ---
# For local/dev/demo without Firebase credentials, set RTDB_MODE=memory
RTDB_MODE=                # "memory" = in-process store (no Firebase needed)
FIREBASE_DB_URL=https://your-db.firebaseio.com
# Mode A: legacy DB auth secret
FIREBASE_AUTH_SECRET=
# Mode B (preferred if set): service account credentials JSON / base64 / path
FIREBASE_SERVICE_ACCOUNT=
RTDB_EXEC_QUEUE_PATH=/exec-queue

# --- cronjob.org ---
CRONJOB_API_BASE=https://api.cron-job.org
# Per-account API keys live in RTDB /accounts — never hardcode here.

# --- Executor ---
EXEC_HANDLERS_DIR=./handlers
EXEC_ALLOWED=[]           # whitelist handler names; [] = allow all files in dir
EXEC_TIMEOUT_MS=30000
EXEC_CONCURRENCY=3
EXEC_LOG_PAYLOAD=false    # beware secrets in payloads

# --- Optional at-rest secret encryption ---
SECRET_ENCRYPTION_KEY=    # if set, tokens/PATs are AES-256-GCM encrypted in RTDB
